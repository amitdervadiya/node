<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Store Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 font-sans leading-relaxed">
    <nav class="bg-gray-900 text-white shadow-md">
        <div class="container mx-auto flex justify-center space-x-4 py-4">
            <a href="/education"
                class="text-gray-300 hover:bg-gray-700 hover:text-white px-4 py-2 rounded-lg transition duration-300">Education</a>
            <a href="/recipe"
                class="text-gray-300 hover:bg-gray-700 hover:text-white px-4 py-2 rounded-lg transition duration-300">Recipe</a>
            <a href="/History"
                class="text-gray-300 hover:bg-gray-700 hover:text-white px-4 py-2 rounded-lg transition duration-300">History</a>
            <a href="/Fantasy"
                class="text-gray-300 hover:bg-gray-700 hover:text-white px-4 py-2 rounded-lg transition duration-300">Fantasy</a>
            <a href="/random"
                class="text-gray-300 hover:bg-gray-700 hover:text-white px-4 py-2 rounded-lg transition duration-300">Random</a>
        </div>
    </nav>

    <header class="bg-indigo-800 py-8">
        <h1 class="text-center text-white text-4xl font-bold tracking-wide">Book Store Management</h1>
    </header>

    <main class="container mx-auto px-6 py-10">

        <section class="bg-white shadow-lg rounded-lg p-8 mb-12">
            <h2 class="text-3xl font-semibold text-gray-800 mb-6 text-center">Add New Book</h2>
            <form action="/adddata" enctype="multipart/form-data" method="post" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="name" class="block text-gray-700 font-medium">Name</label>
                        <input id="name" type="text" placeholder="Enter book name" name="name" required
                            class="w-full border border-gray-300 rounded-md p-3 focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label for="category" class="block text-gray-700 font-medium">Category</label>
                        <input id="category" type="text" placeholder="Enter category" name="category" required
                            class="w-full border border-gray-300 rounded-md p-3 focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label for="publishdate" class="block text-gray-700 font-medium">Publish Date</label>
                        <input id="publishdate" type="date" name="publishdate" required
                            class="w-full border border-gray-300 rounded-md p-3 focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label for="author" class="block text-gray-700 font-medium">Author</label>
                        <input id="author" type="text" placeholder="Enter author name" name="author" required
                            class="w-full border border-gray-300 rounded-md p-3 focus:ring-2 focus:ring-indigo-500">
                    </div>
                </div>
                <div>
                    <label for="image" class="block text-gray-700 font-medium">Image</label>
                    <input id="image" type="file" name="image"
                        class="w-full border border-gray-300 rounded-md p-3 focus:ring-2 focus:ring-indigo-500">
                </div>
                <div class="text-center">
                    <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg shadow-md transition">
                        Add Book
                    </button>
                </div>
            </form>
        </section>

     
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% data.map((e, i) => { %>
            <div
                class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition transform hover:-translate-y-2">
                <img src="<%= e.image %>" alt="Book Image"
                    class="h-48 w-full object-cover border-b-2 border-gray-200">
                <div class="p-6 flex flex-col">
                    <h3 class="text-lg font-bold text-gray-800 mb-2"><%= e.name %></h3>
                    <p class="text-gray-600 mb-2"><span class="font-medium">Category:</span> <%= e.category %></p>
                    <p class="text-gray-600 mb-2"><span class="font-medium">Publish Date:</span> <%= e.publishdate %>
                    </p>
                    <p class="text-gray-600 mb-4"><span class="font-medium">Author:</span> <%= e.author %></p>
                    <div class="flex justify-between mt-auto">
                        <a href="/editdata?id=<%= e.id %>"
                            class="bg-green-500 text-white px-4 py-2 rounded-md hover:bg-green-600 transition">Edit</a>
                        <a href="/deletedata?id=<%= e.id %>"
                            class="bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-600 transition">Delete</a>
                    </div>
                </div>
            </div>
            <% }); %>
        </section>
    </main>
</body>

</html>
